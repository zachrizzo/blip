{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "UI (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@paperclipai/ui", "dev"],
      "port": 5173
    },
    {
      "name": "Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@paperclipai/server", "dev"],
      "port": 3100
    },
    {
      "name": "Full Dev (UI + Server)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:ui"],
      "port": 5173
    }
  ]
}
