{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "UI (Vite)",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH pnpm --filter @paperclipai/ui dev"],
      "port": 5173
    },
    {
      "name": "Server",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH pnpm --filter @paperclipai/server dev"],
      "port": 3100
    },
    {
      "name": "Full Dev (UI + Server)",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH pnpm dev:ui"],
      "port": 5173
    }
  ]
}
